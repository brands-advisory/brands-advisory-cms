@using BrandsAdvisory.Client.Models
@page "/admin/articles/{id}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@attribute [Authorize]
@inject AuthenticationStateProvider AuthStateProvider
@inject IOwnerService OwnerService
@inject IArticleRepository ArticleRepo
@inject NavigationManager Nav
@inject ClientConfig Config
@inject IJSRuntime JSRuntime

<PageTitle>@(_isNew ? "New Article" : "Edit Article") · Brands Advisory</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">@(_isNew ? "New Article" : "Edit Article")</h2>
    <div class="d-flex gap-2">
        @if (!_isNew)
        {
            <button class="btn btn-outline-danger btn-sm" @onclick="DeleteAsync" disabled="@_deleting"
                    title="Delete article">
                🗑
            </button>
        }
        <button class="btn btn-outline-secondary btn-sm" @onclick="Cancel">Cancel</button>
        <button class="btn btn-outline-light btn-sm" @onclick="SaveAsync" disabled="@_saving">
            @(_saving ? "Saving…" : "Save")
        </button>
    </div>
</div>

@if (!_ready)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-secondary" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
    </div>
}
else
{
    <div class="card-dark p-4 d-flex flex-column gap-3">

        <div>
            <label class="form-label text-secondary small">Title</label>
            <input class="form-control bg-dark text-white border-secondary"
                   @bind="_article.Title" />
        </div>

        <div>
            <label class="form-label text-secondary small">Slug</label>
            <input class="form-control bg-dark text-white border-secondary"
                   @bind="_article.Slug" />
        </div>

        <div>
            <label class="form-label text-secondary small">Summary</label>
            <textarea class="form-control bg-dark text-white border-secondary" rows="3"
                      @bind="_article.Summary"></textarea>
        </div>

        <div>
            <label class="form-label text-secondary small">Tags (comma-separated)</label>
            <input class="form-control bg-dark text-white border-secondary"
                   @bind="_tagsInput" />
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch"
                       id="publishedToggle"
                       @bind="_article.IsPublished" />
                <label class="form-check-label text-secondary small" for="publishedToggle">
                    Published
                </label>
            </div>
            @if (_article.IsPublished && _article.PublishedDate.HasValue)
            {
                <span class="text-secondary small">
                    @_article.PublishedDate.Value.ToString("MMMM d, yyyy")
                </span>
            }
        </div>

        <div>
            <label class="form-label text-secondary small">Content</label>
            <SfRichTextEditor Value="@_article.Content"
                              ValueChanged="@OnContentChanged"
                              Height="500px">
                <RichTextEditorToolbarSettings Items="@_toolbarItems" />
                <RichTextEditorImageSettings SaveUrl="/api/images/upload"
                                             Path="@Config.ImageContainerUrl" />
                <RichTextEditorEvents OnImageUploadSuccess="@OnImageUploadSuccess" />
            </SfRichTextEditor>
        </div>

    </div>
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Article _article = new();
    private string _tagsInput = string.Empty;
    private bool _isNew;
    private bool _ready;
    private bool _saving;
    private bool _deleting;

    private readonly List<ToolbarItemModel> _toolbarItems =
    [
        new() { Command = ToolbarCommand.Bold },
        new() { Command = ToolbarCommand.Italic },
        new() { Command = ToolbarCommand.Underline },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.Formats },
        new() { Command = ToolbarCommand.OrderedList },
        new() { Command = ToolbarCommand.UnorderedList },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.CreateLink },
        new() { Command = ToolbarCommand.Image },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.SourceCode },
        new() { Command = ToolbarCommand.FullScreen }
    ];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!OwnerService.IsOwner(authState.User))
        {
            Nav.NavigateTo("/articles");
            return;
        }

        _isNew = string.Equals(Id, "new", StringComparison.OrdinalIgnoreCase);

        if (_isNew)
        {
            _article = new Article { Id = Guid.NewGuid().ToString() };
        }
        else
        {
            var existing = await ArticleRepo.GetByIdAsync(Id);
            if (existing is null)
            {
                Nav.NavigateTo("/articles");
                return;
            }
            _article = existing;
            _tagsInput = string.Join(", ", _article.Tags);
        }

        _ready = true;
    }

    private async Task SaveAsync()
    {
        _saving = true;

        _article.Tags = _tagsInput
            .Split(',')
            .Select(t => t.Trim())
            .Where(t => !string.IsNullOrEmpty(t))
            .ToList();

        if (_article.IsPublished && _article.PublishedDate is null)
            _article.PublishedDate = DateTime.UtcNow;

        if (!_article.IsPublished)
            _article.PublishedDate = null;

        await ArticleRepo.UpsertAsync(_article);
        Nav.NavigateTo($"/articles/{_article.Slug}");
    }

    // OnImageUploadSuccess fires BEFORE ValueChanged updates _article.Content.
    // Store the pending fix here; OnContentChanged applies it when ValueChanged fires.
    private string? _pendingWrongSrc;
    private string? _pendingBlobUrl;

    private void OnImageUploadSuccess(ImageSuccessEventArgs args)
    {
        var blobUrl = ParseXBlobUrlHeader(args.Response?.Headers);
        if (string.IsNullOrEmpty(blobUrl)) return;
        _pendingWrongSrc = Config.ImageContainerUrl.TrimEnd('/') + "/" + args.File?.Name;
        _pendingBlobUrl = blobUrl;
    }

    private async Task OnContentChanged(string value)
    {
        string? wrongSrc = null;
        string? correctSrc = null;

        if (_pendingWrongSrc is not null && _pendingBlobUrl is not null
            && value.Contains(_pendingWrongSrc))
        {
            wrongSrc = _pendingWrongSrc;
            correctSrc = _pendingBlobUrl;
            value = value.Replace(wrongSrc, correctSrc);
            _pendingWrongSrc = null;
            _pendingBlobUrl = null;
        }

        _article.Content = value;

        // Also patch the editor DOM so the image displays immediately.
        if (wrongSrc is not null && correctSrc is not null)
            await JSRuntime.InvokeVoidAsync("sfFixImageSrc", wrongSrc, correctSrc);
    }

    private static string? ParseXBlobUrlHeader(string? headers)
    {
        if (string.IsNullOrEmpty(headers)) return null;
        foreach (var line in headers.Split(["\r\n", "\n"], StringSplitOptions.RemoveEmptyEntries))
        {
            if (line.StartsWith("x-blob-url:", StringComparison.OrdinalIgnoreCase))
                return line["x-blob-url:".Length..].Trim();
        }
        return null;
    }

    private void Cancel() => Nav.NavigateTo("/articles");

    private async Task DeleteAsync()
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Delete '{_article.Title}'? This cannot be undone."))
            return;

        _deleting = true;
        await ArticleRepo.DeleteAsync(_article.Id);
        Nav.NavigateTo("/articles");
    }
}
