@inherits LayoutComponentBase
@inject IOwnerService OwnerService
@inject IHttpContextAccessor HttpContextAccessor

<CascadingValue Value="@_isOwner" Name="IsOwner">

    <nav class="navbar navbar-dark sticky-top" style="background-color: #0d1117;">
        <div class="container" style="max-width: 900px;">

            <!-- Left: Avatar + Brand -->
            <a class="navbar-brand d-flex align-items-center gap-2 text-decoration-none" href="/">
                <img src="/images/avatar.jpg"
                     class="rounded-circle"
                     width="40" height="40"
                     style="object-fit: cover;"
                     alt="Brands Advisory avatar" />
                <div class="lh-sm">
                    <div class="fw-bold text-white" style="font-size: 0.875rem;">Brands Advisory</div>
                    <div class="text-secondary" style="font-size: 0.7rem;">Freelance IT Consulting</div>
                </div>
            </a>

            <!-- Center: Navigation tabs -->
            <div class="d-flex gap-1">
                <NavLink href="/"
                         Match="NavLinkMatch.All"
                         class="nav-pill-inactive"
                         ActiveClass="nav-pill-active">
                    About
                </NavLink>
                <NavLink href="/projects"
                         class="nav-pill-inactive"
                         ActiveClass="nav-pill-active">
                    Projects
                </NavLink>
                <NavLink href="/articles"
                         class="nav-pill-inactive"
                         ActiveClass="nav-pill-active">
                    Articles
                </NavLink>
            </div>

            <!-- Right: Login/Logout -->
            <div class="d-flex align-items-center">
                <AuthorizeView>
                    <Authorized>
                        <form method="post" action="/logout">
                            <AntiforgeryToken />
                            <button type="submit" class="btn btn-outline-secondary btn-sm">Logout</button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="btn btn-outline-secondary btn-sm">Login</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>

        </div>
    </nav>

    <main class="container py-4" style="max-width: 900px;">
        @Body
    </main>

    <footer class="border-top border-secondary py-3 small" style="background-color: #0d1117;">
        <div class="container d-flex justify-content-between align-items-center" style="max-width: 900px;">
            <span class="text-secondary">&copy; 2026 Brands Advisory</span>
            <span></span>
            <span class="text-secondary d-flex align-items-center gap-3">
                <a href="https://robert-brands.com" class="text-secondary text-decoration-none">robert-brands.com</a>
                <span aria-hidden="true">&middot;</span>
                <a href="/legal" class="text-secondary text-decoration-none">Legal</a>
            </span>
        </div>
    </footer>

</CascadingValue>

@code {
    private bool _isOwner;

    protected override void OnInitialized()
    {
        var user = HttpContextAccessor.HttpContext?.User;
        _isOwner = user is not null && OwnerService.IsOwner(user);
    }
}
