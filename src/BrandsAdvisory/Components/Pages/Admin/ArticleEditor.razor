@page "/admin/articles/{id}"
@rendermode InteractiveServer
@attribute [Authorize]
@using Syncfusion.Blazor.RichTextEditor
@inject AuthenticationStateProvider AuthStateProvider
@inject IOwnerService OwnerService
@inject ICosmosDbService CosmosDb
@inject NavigationManager Nav

<PageTitle>@(_isNew ? "New Article" : "Edit Article") · Brands Advisory</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">@(_isNew ? "New Article" : "Edit Article")</h2>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" @onclick="Cancel">Cancel</button>
        <button class="btn btn-outline-light btn-sm" @onclick="SaveAsync" disabled="@_saving">
            @(_saving ? "Saving…" : "Save")
        </button>
    </div>
</div>

@if (!_ready)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-secondary" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
    </div>
}
else
{
    <div class="card-dark p-4 d-flex flex-column gap-3">

        <div>
            <label class="form-label text-secondary small">Title</label>
            <input class="form-control bg-dark text-white border-secondary"
                   @bind="_article.Title" />
        </div>

        <div>
            <label class="form-label text-secondary small">Slug</label>
            <input class="form-control bg-dark text-white border-secondary"
                   @bind="_article.Slug" />
        </div>

        <div>
            <label class="form-label text-secondary small">Summary</label>
            <textarea class="form-control bg-dark text-white border-secondary" rows="3"
                      @bind="_article.Summary"></textarea>
        </div>

        <div>
            <label class="form-label text-secondary small">Tags (comma-separated)</label>
            <input class="form-control bg-dark text-white border-secondary"
                   @bind="_tagsInput" />
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch"
                       id="publishedToggle"
                       @bind="_article.IsPublished" />
                <label class="form-check-label text-secondary small" for="publishedToggle">
                    Published
                </label>
            </div>
            @if (_article.IsPublished && _article.PublishedDate.HasValue)
            {
                <span class="text-secondary small">
                    @_article.PublishedDate.Value.ToString("MMMM d, yyyy")
                </span>
            }
        </div>

        <div>
            <label class="form-label text-secondary small">Content</label>
            <SfRichTextEditor @bind-Value="_article.Content"
                              Height="500px">
                <RichTextEditorToolbarSettings Items="@_toolbarItems" />
            </SfRichTextEditor>
        </div>

    </div>
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Article _article = new();
    private string _tagsInput = string.Empty;
    private bool _isNew;
    private bool _ready;
    private bool _saving;

    private readonly List<ToolbarItemModel> _toolbarItems =
    [
        new() { Command = ToolbarCommand.Bold },
        new() { Command = ToolbarCommand.Italic },
        new() { Command = ToolbarCommand.Underline },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.Formats },
        new() { Command = ToolbarCommand.OrderedList },
        new() { Command = ToolbarCommand.UnorderedList },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.CreateLink },
        new() { Command = ToolbarCommand.Image },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.SourceCode },
        new() { Command = ToolbarCommand.FullScreen }
    ];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!OwnerService.IsOwner(authState.User))
        {
            Nav.NavigateTo("/articles");
            return;
        }

        _isNew = string.Equals(Id, "new", StringComparison.OrdinalIgnoreCase);

        if (_isNew)
        {
            _article = new Article { Id = Guid.NewGuid().ToString() };
        }
        else
        {
            var existing = await CosmosDb.GetArticleByIdAsync(Id);
            if (existing is null)
            {
                Nav.NavigateTo("/articles");
                return;
            }
            _article = existing;
            _tagsInput = string.Join(", ", _article.Tags);
        }

        _ready = true;
    }

    private async Task SaveAsync()
    {
        _saving = true;

        _article.Tags = _tagsInput
            .Split(',')
            .Select(t => t.Trim())
            .Where(t => !string.IsNullOrEmpty(t))
            .ToList();

        if (_article.IsPublished && _article.PublishedDate is null)
            _article.PublishedDate = DateTime.UtcNow;

        if (!_article.IsPublished)
            _article.PublishedDate = null;

        await CosmosDb.UpsertArticleAsync(_article);
        Nav.NavigateTo($"/articles/{_article.Slug}");
    }

    private void Cancel() => Nav.NavigateTo("/articles");
}
