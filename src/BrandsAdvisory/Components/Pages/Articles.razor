@page "/articles"
@attribute [StreamRendering]
@inject IArticleRepository ArticleRepo
@inject IConfiguration Config

<PageTitle>Articles · Brands Advisory</PageTitle>
<HeadContent>
    <meta name="description"
          content="Articles about cloud architecture, Azure, and practical GenAI enablement." />
    <meta property="og:title" content="Articles · Brands Advisory" />
    <meta property="og:description"
          content="Articles about cloud architecture, Azure, and practical GenAI enablement." />
    <meta property="og:url" content="@(Config["SiteUrl"])/articles" />
    <link rel="canonical" href="@(Config["SiteUrl"])/articles" />
</HeadContent>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold mb-0"><span class="me-2">📝</span>Articles</h1>
    @if (IsOwner)
    {
        <a href="/admin/articles/new" class="btn btn-outline-secondary btn-sm">+ New Article</a>
    }
</div>

@if (_articles is null)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-secondary" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
    </div>
}
else if (_articles.Count == 0)
{
    <p class="text-secondary text-center py-5">No articles published yet.</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var article in _articles)
        {
            <div class="col">
                <div class="card h-100 card-dark position-relative">

                    @if (IsOwner)
                    {
                        <a href="/admin/articles/@article.Id"
                           class="btn btn-sm btn-outline-secondary position-absolute top-0 end-0 m-2"
                           title="Edit">✏️</a>
                    }

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title fw-bold mb-1 text-white">@article.Title</h5>

                        <p class="text-secondary small mb-2">
                            @article.PublishedDate?.ToString("MMMM d, yyyy")
                        </p>

                        @if (article.Tags.Any())
                        {
                            <div class="d-flex flex-wrap gap-1 mb-3">
                                @foreach (var tag in article.Tags)
                                {
                                    <span class="badge rounded-pill bg-secondary fw-normal text-white">@tag</span>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(article.Summary))
                        {
                            <p class="card-text text-secondary small flex-grow-1">@article.Summary</p>
                        }

                        <a href="/articles/@article.Slug"
                           class="text-secondary text-decoration-none small mt-3">
                            Read more →
                        </a>

                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter(Name = "IsOwner")]
    public bool IsOwner { get; set; }

    private List<Article>? _articles;

    protected override async Task OnInitializedAsync()
    {
        _articles = IsOwner
            ? await ArticleRepo.GetAllAsync()
            : await ArticleRepo.GetPublishedAsync();
    }
}
