@page "/projects"
@attribute [StreamRendering]
@inject IProjectRepository ProjectRepo

<PageTitle>Projects · Brands Advisory</PageTitle>

@if (IsOwner)
{
    <div class="d-flex justify-content-end mb-3">
        <a href="/admin/projects" class="btn btn-outline-secondary btn-sm">✏️ Edit Projects</a>
    </div>
}

@if (_projects is null)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-secondary" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
    </div>
}
else if (_projects.Count == 0)
{
    <p class="text-secondary text-center py-5">No projects yet.</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var project in _projects)
        {
            <div class="col">
                <div class="card-dark p-3 h-100">
                    <h5 class="fw-bold mb-1">@project.Title</h5>
                    <div class="text-secondary small mb-2">@project.Customer · @project.Period</div>

                    @if (project.Tags.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            @foreach (var tag in project.Tags)
                            {
                                <span class="tag-pill" style="font-size:0.75rem; padding:2px 8px;">@tag</span>
                            }
                        </div>
                    }

                    <p class="text-secondary small mb-0"
                       style="overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
                        @project.Description
                    </p>
                </div>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter(Name = "IsOwner")]
    public bool IsOwner { get; set; }

    private List<Project>? _projects;

    protected override async Task OnInitializedAsync()
    {
        _projects = await ProjectRepo.GetAllAsync();
    }
}
