@inject IConfiguration Config
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="_content/Syncfusion.Blazor.Themes/bootstrap5-dark.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["BrandsAdvisory.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <meta name="robots" content="index, follow" />
    <meta property="og:site_name" content="Brands Advisory" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta property="og:image" content="@(Config["SiteUrl"])/images/og-image.png" />
    <link rel="apple-touch-icon" href="/images/icon-192.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="_content/Syncfusion.Blazor.Core/scripts/syncfusion-blazor.min.js" type="text/javascript"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        // Patches the img src inside the Syncfusion RTE editor DOM.
        // Called after an image upload to correct the GUID blob URL that
        // Syncfusion would otherwise set to Path + originalFilename.
        window.sfFixImageSrc = function (wrongSrc, correctSrc) {
            document.querySelectorAll('.e-content img').forEach(function (img) {
                if (img.getAttribute('src') === wrongSrc) {
                    img.setAttribute('src', correctSrc);
                }
            });
        };
    </script>
</body>

</html>
