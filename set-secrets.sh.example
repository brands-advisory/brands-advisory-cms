#!/bin/bash
# Run from repository root
PROJECT="src/BrandsAdvisory/BrandsAdvisory.csproj"

dotnet user-secrets set "AzureAd:TenantId" "__TENANT_ID__" -p $PROJECT
dotnet user-secrets set "AzureAd:ClientId" "__CLIENT_ID__" -p $PROJECT
dotnet user-secrets set "AzureAd:ClientCertificates:0:SourceType" "KeyVault" -p $PROJECT
dotnet user-secrets set "AzureAd:ClientCertificates:0:KeyVaultUrl" "__KEYVAULT_URI__" -p $PROJECT
dotnet user-secrets set "AzureAd:ClientCertificates:0:KeyVaultCertificateName" "__KEYVAULT_CERT_NAME__" -p $PROJECT
dotnet user-secrets set "CosmosDb:EndpointUri" "__COSMOS_ENDPOINT__" -p $PROJECT
dotnet user-secrets set "CosmosDb:DatabaseId" "__DATABASE_ID__" -p $PROJECT
dotnet user-secrets set "CosmosDb:ContainerName" "__CONTAINER_NAME__" -p $PROJECT
# Cosmos DB access uses Managed Identity - no key required.
# For local development, run: az login
# DefaultAzureCredential will use your Azure CLI credentials automatically.
